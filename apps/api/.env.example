# Kopyala: copy .env.example .env  (Windows: copy .env.example .env)

# PostgreSQL — repo kökünde: docker compose up -d  (varsayılan port 5433, docker-compose.yml ile aynı)
DATABASE_URL="postgresql://nextpos:nextpos@127.0.0.1:5433/nextpos"

# JWT (üretimde güçlü rastgele değerler kullanın)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Opsiyonel: docker compose up -d ile Redis (ileride kuyruk / cache)
# REDIS_URL=redis://127.0.0.1:6379

# CORS / Socket — virgülle birden fazla origin (Vite portları veya üretim domain’leri)
# Yerel varsayılanlar + örnek üretim (webotonom):
# CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://localhost:5176,http://localhost:4000,http://localhost:4001,http://localhost:4003,https://pos.webotonom.de,https://admin.webotonom.de,https://reseller.webotonom.de
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:4000,http://localhost:4001,http://localhost:4003
SOCKET_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:4000,http://localhost:4001,http://localhost:4003

# API portu (ör. üretim gateway: 5000). Varsayılan: 3001
# PORT=5000

# Üretim: Nginx arkasında gerçek istemci IP (rate limit). Yerelde genelde tanımlama.
# TRUST_PROXY=1

# Giriş rate limit (varsayılan: 40 / 15 dk, refresh 90 / dk)
# AUTH_LOGIN_MAX_PER_WINDOW=40
# AUTH_REFRESH_MAX_PER_MIN=90

# Başarısız şifre/PIN/SaaS denemesi — bellek içi kilit (varsayılan 5 deneme / 15 dk)
# AUTH_LOCKOUT_MAX_FAILS=5
# AUTH_LOCKOUT_MINUTES=15

# Sipariş: birim fiyatlar KDV dahil (brüt). Matrah/KDV ayrımı (varsayılan %18, POS ile uyumlu)
# DEFAULT_VAT_RATE=0.18

# QR Web Menü (alt domain: qrpizza.hpdemos.de gibi) — üretimde wildcard DNS + SSL
# Modül kodu: qr_web_menu (SaaS ek modül veya plan kuralı "included")
# QR_WEB_PARENT_DOMAIN=hpdemos.de
# Yerelde modül kontrolünü zorlamak: QR_WEB_ENFORCE_MODULE=1
# Üretimde geçici olarak modül kontrolünü kapatmak: QR_WEB_SKIP_MODULE_CHECK=1

# Mutfak API vb. tenant modül zorlamasını yerelde kapatmak (geliştirme)
# DEV_SKIP_TENANT_MODULE_ENFORCEMENT=1
