        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.13.0",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^7.0.11",
        "@types/pdfkit": "^0.17.5",
        "@types/pg": "^8.20.0",
        "eslint": "^9.39.4",
