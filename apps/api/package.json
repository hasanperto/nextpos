        "@types/uuid": "^10.0.0",
        "archiver": "^7.0.1",
        "axios": "^1.14.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "csv-writer": "^1.6.0",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "helmet": "^8.0.0",
        "iyzipay": "^2.0.67",
        "jsonwebtoken": "^9.0.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.4",
        "pdfkit": "^0.18.0",
        "pg": "^8.20.0",
        "redis": "^5.11.0",
        "socket.io": "^4.8.1",
        "stripe": "^17.7.0",
        "uuid": "^13.0.0",
