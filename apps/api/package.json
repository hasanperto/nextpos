{
    "name": "@nextpos/api",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "prebuild": "prisma generate",
        "build": "tsc && node ./scripts/copy-billing-sql.mjs",
