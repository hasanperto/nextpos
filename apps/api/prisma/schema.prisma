// NextPOS — Prisma Schema (PostgreSQL — Multi-Tenant SaaS)
// public schema: Merkezi SaaS verileri (tenants, languages, sync_queue)
// Tenant-spesifik veriler: pg pool + SET search_path ile yönetilir

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// MERKEZI SaaS TABLOSU (public schema)
// ═══════════════════════════════════════

/// Her restoran/kiracı için merkezi kayıt.
/// Tenant-specific tablolar pg pool ile dinamik olarak yönetilir.
model Tenant {
  id               String    @id @default(uuid()) @db.VarChar(36)
  name             String    @db.VarChar(255)
  schemaName       String    @unique @map("schema_name") @db.VarChar(255)
  status           String    @default("active") @db.VarChar(50)
  subscriptionPlan String    @default("basic") @map("subscription_plan") @db.VarChar(50)
  licenseExpiresAt DateTime? @map("license_expires_at") @db.Timestamp(0)
  maxUsers         Int       @default(10) @map("max_users")
  maxBranches      Int       @default(1) @map("max_branches")
  contactEmail      String?   @map("contact_email") @db.VarChar(255)
  contactPhone      String?   @map("contact_phone") @db.VarChar(30)
  authorizedPerson  String?   @map("authorized_person") @db.VarChar(100)
  taxOffice         String?   @map("tax_office") @db.VarChar(100)
  taxNumber         String?   @map("tax_number") @db.VarChar(50)
  specialLicenseKey String?   @unique @map("special_license_key") @db.VarChar(100)
  address           String?   @db.Text
  settings          Json?     @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("tenants")
}

model SaasAdmin {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String    @map("full_name") @db.VarChar(100)
  lastLogin    DateTime? @map("last_login") @db.Timestamp(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  @@map("saas_admins")
}

// ═══════════════════════════════════════
// ÇOKLU DİL (i18n) — Merkezi (public schema)
// ═══════════════════════════════════════

model Language {
  code       String  @id @db.VarChar(5)
  name       String  @db.VarChar(50)
  nativeName String  @map("native_name") @db.VarChar(50)
  flagEmoji  String? @map("flag_emoji") @db.VarChar(10)
  direction  String  @default("ltr") @db.VarChar(3)
  isActive   Boolean @default(true) @map("is_active")
  sortOrder  Int     @default(0) @map("sort_order")

  uiTranslations UiTranslation[]

  @@map("languages")
}

model UiTranslation {
  id        Int      @id @default(autoincrement())
  namespace String   @db.VarChar(50)
  key       String   @db.VarChar(200)
  lang      String   @db.VarChar(5)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  language Language @relation(fields: [lang], references: [code])

  @@unique([namespace, key, lang])
  @@index([namespace, lang])
  @@map("ui_translations")
}

// ═══════════════════════════════════════
// OFFLİNE SENKRONIZASYON — Merkezi (public schema)
// ═══════════════════════════════════════

model SyncQueue {
  id           Int       @id @default(autoincrement())
  tenantId     String    @map("tenant_id") @db.VarChar(36)
  entityType   String    @map("entity_type") @db.VarChar(50)
  entityId     String?   @map("entity_id") @db.VarChar(50)
  action       String    @db.VarChar(20)
  payload      Json
  status       String    @default("pending") @db.VarChar(20)
  retryCount   Int       @default(0) @map("retry_count")
  errorMessage String?   @map("error_message") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  syncedAt     DateTime? @map("synced_at") @db.Timestamp(0)

  @@index([status])
  @@index([tenantId])
  @@map("sync_queue")
}

// ═══════════════════════════════════════
// DESTEK VE SİSTEM — Merkezi (public schema)
// ═══════════════════════════════════════

model SupportTicket {
  id          Int      @id @default(autoincrement())
  tenantId    String   @map("tenant_id") @db.VarChar(36)
  subject     String   @db.VarChar(255)
  message     String   @db.Text
  status      String   @default("open") @db.VarChar(20) // open, in_progress, closed
  priority    String   @default("medium") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("support_tickets")
}

model SystemBackup {
  id          Int      @id @default(autoincrement())
  filename    String   @db.VarChar(255)
  size        BigInt
  status      String   @default("success") @db.VarChar(20)
  createdBy   String   @map("created_by") @db.VarChar(255) // SaaS Admin username
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  @@map("system_backups")
}
