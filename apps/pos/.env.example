# apps/pos — kopyala: copy .env.example .env.local
# Vite bu dosyayı otomatik yükler (vite.config.ts loadEnv).

# Geliştirme sunucusu portu (ör. üretim benzeri: 4003)
# DEV_SERVER_PORT=4003

# Ağ arayüzü: yerelde 127.0.0.1; LAN’dan erişim için 0.0.0.0
# DEV_SERVER_HOST=127.0.0.1

# Port doluysa çıkış (varsayılan açık; kapatmak için 0/false)
# DEV_SERVER_STRICT_PORT=1

# API proxy hedefi — backend hangi host:port’ta çalışıyorsa
# API_PROXY_TARGET=http://127.0.0.1:5000

# Socket.io doğrudan API’ye (Vite WS proxy sorun çıkarırsa; CORS/SOCKET_CORS_ORIGIN API’de açık olmalı)
# VITE_SOCKET_ORIGIN=http://127.0.0.1:3001

# (İsteğe bağlı) Yazıcı listesi köprüsü tam URL — boşsa dev’de /__printer_agent, prod’da http://127.0.0.1:3910/printers
# VITE_PRINTER_AGENT_LIST_URL=http://127.0.0.1:3910/printers

# Çevrimdışı senkron kuyruğu: bu saatten eski bekleyen kayıtlar silinir (24–168; varsayılan 48)
# VITE_OFFLINE_SYNC_MAX_HOURS=48
